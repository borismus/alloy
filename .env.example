# Vault used by `npm run dev` (web mode). Set this to your real vault and copy
# this file to .env (gitignored) — then `npm run dev` just works.
ALLOY_VAULT=/path/to/your/vault

# Tauri update signing (optional — only needed for signed releases)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Apple code signing & notarization (optional — only needed for macOS releases)
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
