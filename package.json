{
  "name": "alloy",
  "version": "0.3.11",
  "description": "Local-first multi-model AI chat app. One helm for Claude, ChatGPT, Gemini, Grok, and local models.",
  "author": "Boris Smus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borismus/alloy.git"
  },
  "homepage": "https://github.com/borismus/alloy#readme",
  "bugs": {
    "url": "https://github.com/borismus/alloy/issues"
  },
  "keywords": [
    "ai",
    "chat",
    "claude",
    "openai",
    "gemini",
    "ollama",
    "tauri",
    "local-first"
  ],
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "tsc && eslint . && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "tauri": "bash scripts/tauri-with-logs.sh",
    "clean": "rm -rf dist dist-web .vite playwright-report test-results && cd src-tauri && cargo clean",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install chromium",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@soniox/speech-to-text-web": "^1.4.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.5.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "js-yaml": "^4.1.1",
    "mermaid": "^11.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@tauri-apps/cli": "^2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4",
    "vitest": "^4.0.16"
  }
}
